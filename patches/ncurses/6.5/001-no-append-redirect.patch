+			"$srcdir/$cf_dir/modules" >$cf_dir/Makefile._append
+		cp $cf_dir/Makefile $cf_dir/Makefile._bak
+		cat $cf_dir/Makefile._bak $cf_dir/Makefile._append >$cf_dir/Makefile
